@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <h1>Admin Dashboard</h1>
    <p class="text-muted">System Overview & Management Tools</p>
    <hr />

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Students</h5>
                    <h2>@ViewBag.TotalStudents.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Supervisors</h5>
                    <h2>@ViewBag.TotalSupervisors.Count</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <h5 class="card-title">Pending Proposals</h5>
                    <h2>@ViewBag.PendingProposals</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Matched Projects</h5>
                    <h2>@ViewBag.MatchedProposals</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Section -->
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">📚 Research Areas</h5>
                    <p class="card-text">Manage research areas available in the system.</p>
                    <a href="@Url.Action("ResearchAreas", "Admin")" class="btn btn-sm btn-primary">Manage Areas</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">👥 User Management</h5>
                    <p class="card-text">Assign roles and manage user accounts.</p>
                    <a href="@Url.Action("Users", "Admin")" class="btn btn-sm btn-primary">Manage Users</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">🤝 Project Matches</h5>
                    <p class="card-text">View and manage matched projects and supervisors.</p>
                    <a href="@Url.Action("Matches", "Admin")" class="btn btn-sm btn-primary">View Matches</a>
                </div>
            </div>
        </div>
    </div>
</div>
