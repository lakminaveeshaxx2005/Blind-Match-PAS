@model IEnumerable<Blind_Match_PAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Manage Allocations";
    var supervisors = ViewBag.Supervisors as List<Blind_Match_PAS.Models.ApplicationUser> ?? new
List<Blind_Match_PAS.Models.ApplicationUser>();
    var studentNameMap = (Dictionary<string, string>)ViewBag.StudentNameMap ?? new Dictionary<string, string>();
    var supervisorNameMap = (Dictionary<string, string>)ViewBag.SupervisorNameMap ?? new Dictionary<string, string>();
}

<div class="container-fluid mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>@ViewData["Title"]</h1>
            <p class="text-muted">View all matched student-supervisor allocations and reassign supervisors manually.</p>
        </div>
        <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive shadow-sm">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Project Title</th>
                    <th>Student</th>
                    <th>Supervisor</th>
                    <th>Status</th>
                    <th>Match Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var match in Model)
                {
                    var studentName = studentNameMap.ContainsKey(match.StudentId) ? studentNameMap[match.StudentId] :
          "Unknown Student";
                    var supervisorName = !string.IsNullOrEmpty(match.SupervisorId) &&
                supervisorNameMap.ContainsKey(match.SupervisorId) ? supervisorNameMap[match.SupervisorId] :
           "Unassigned";

                    <tr>
                        <td>@match.Title</td>
                        <td>@studentName</td>
                        <td>@supervisorName</td>
                        <td><span class="badge bg-success">Matched</span></td>
                        <td>@(match.MatchedAt?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal"
                                    data-bs-target="#reassignModal@match.Id">
                                <i class="bi bi-arrow-repeat"></i> Reassign
                            </button>
                        </td>
                    </tr>

                    <div class="modal fade" id="reassignModal@match.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Reassign Supervisor</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form asp-action="Reassign" asp-controller="Admin" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="modal-body">
                                        <input type="hidden" name="proposalId" value="@match.Id" />
                                        <div class="mb-3">
                                            <label class="form-label">Current Supervisor</label>
                                            <input type="text" class="form-control" value="@supervisorName" disabled />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">New Supervisor</label>
                                            <select name="newSupervisorId" class="form-select" required>
                                                <option value="">Select supervisor</option>
                                                @foreach (var supervisor in supervisors)
                                                {
                                                    if (supervisor.Id == match.SupervisorId)
                                                    {
                                                        <option value="@supervisor.Id" selected>@supervisor.FullName
                                                            (@supervisor.Email)</option>
                                                        }
                                                    else
                                                        {
                                                            <option value="@supervisor.Id">@supervisor.FullName (@supervisor.Email)
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary"
                                                    data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Reassign</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
