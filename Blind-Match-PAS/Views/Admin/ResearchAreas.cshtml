@model IEnumerable<Blind_Match_PAS.Models.ResearchAreaWithStats>

@{
    ViewData["Title"] = "Research Areas Management";
}

<div class="container-fluid mt-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 fw-bold">
                        <i class="bi bi-tags-fill"></i> Research Areas Management
                    </h1>
                    <p class="text-muted">Define and manage research areas for project categorization</p>
                </div>
                <a href="@Url.Action("CreateResearchArea", "Admin")" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-lg"></i> Add New Area
                </a>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Research Areas Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-gradient" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
            <h5 class="mb-0 text-white">
                <i class="bi bi-list-ul"></i> All Research Areas
            </h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> No research areas have been created yet.
                    <a href="@Url.Action("CreateResearchArea", "Admin")" class="alert-link">Create your first research
                        area</a>.
                    </div>
                }
            else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">
                                        <i class="bi bi-hash"></i> ID
                                    </th>
                                    <th scope="col">
                                        <i class="bi bi-tag"></i> Area Name
                                    </th>
                                    <th scope="col">
                                        <i class="bi bi-calendar"></i> Created
                                    </th>
                                    <th scope="col" class="text-center">
                                        <i class="bi bi-bar-chart"></i> Usage Statistics
                                    </th>
                                    <th scope="col" class="text-center" style="width: 200px;">
                                        <i class="bi bi-gear"></i> Actions
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var area in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary">@area.Id</span>
                                        </td>
                                        <td>
                                            <strong>@area.Name</strong>
                                        </td>
                                        <td>
                                            <small class="text-muted">@area.CreatedAt.ToString("MMM dd, yyyy")</small>
                                        </td>
                                        <td class="text-center">
                                            <div class="row">
                                                <div class="col-4">
                                                    <div class="text-muted small">Total</div>
                                                    <div class="fw-bold">@area.TotalProposals</div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="text-muted small">Pending</div>
                                                    <div class="fw-bold text-warning">@area.PendingProposals</div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="text-muted small">Matched</div>
                                                    <div class="fw-bold text-success">@area.MatchedProposals</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <a href="@Url.Action("EditResearchArea", "Admin", new { id = area.Id })"
                                                   class="btn btn-sm btn-outline-warning me-1" title="Edit Area">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <form asp-action="DeleteResearchArea" asp-controller="Admin" asp-route-id="@area.Id"
                                                  method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Are you sure you want to delete this research area? This action cannot be undone.')"
                                                        title="Delete Area">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Quick Stats Footer -->
        @if (Model.Any())
        {
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6 class="text-muted mb-2">Quick Statistics</h6>
                            <div class="row">
                                <div class="col-md-4">
                                    <h4 class="text-primary">@Model.Count()</h4>
                                    <small class="text-muted">Total Research Areas</small>
                                </div>
                                <div class="col-md-4">
                                    <h4 class="text-info">@ViewBag.TotalProposals</h4>
                                    <small class="text-muted">Total Proposals</small>
                                </div>
                                <div class="col-md-4">
                                    <h4 class="text-success">@ViewBag.TotalMatches</h4>
                                    <small class="text-muted">Active Matches</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    }
