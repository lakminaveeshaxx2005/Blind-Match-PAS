@model IEnumerable<Blind_Match_PAS.Models.ResearchArea>

@{
    ViewData["Title"] = "Manage Research Areas";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <a href="@Url.Action("CreateResearchArea", "Admin")" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add New Area
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Proposals</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var area in Model)
                {
                    <tr>
                        <td>@area.Id</td>
                        <td>@area.Name</td>
                        <td><span class="badge bg-secondary">0</span></td>
                        <td>
                            <a href="@Url.Action("EditResearchArea", "Admin", new { id = area.Id })"
                               class="btn btn-sm btn-warning">Edit</a>
                            <form asp-action="DeleteResearchArea" asp-controller="Admin" asp-route-id="@area.Id"
                                  method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
