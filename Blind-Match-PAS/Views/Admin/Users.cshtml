@model IEnumerable<Blind_Match_PAS.Models.UserWithRole>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-5">
    <h1>@ViewData["Title"]</h1>
    <p class="text-muted">Assign roles to users (Student, Supervisor, Admin)</p>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter by Role -->
    <div class="mb-3">
        <div class="btn-group" role="group">
            <a href="@Url.Action("Users", "Admin")"
               class="btn btn-outline-primary @(ViewBag.SelectedRole == "" ? "active" : "")">All Users</a>
            @foreach (var role in ViewBag.Roles)
            {
                <a href="@Url.Action("Users", "Admin", new { role = role })"
                   class="btn btn-outline-primary @(ViewBag.SelectedRole == role ? "active" : "")">@role</a>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Email</th>
                    <th>Current Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var userWithRole in Model)
                {
                    <tr>
                        <td>@userWithRole.User.Email</td>
                        <td>
                            @if (userWithRole.Roles.Any())
                            {
                                @foreach (var role in userWithRole.Roles)
                                {
                                    <span class="badge bg-info me-1">@role</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No Role</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("AssignRole", "Admin", new { userId = userWithRole.User.Id })"
                               class="btn btn-sm btn-warning me-2">Update Role</a>
                            <form asp-action="DeleteUser" asp-controller="Admin" method="post" class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this user?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@userWithRole.User.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
