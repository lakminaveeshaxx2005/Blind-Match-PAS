@model Blind_Match_PAS.Models.MatchingRequest

@{
    ViewData["Title"] = "Edit Matching Request";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Edit Matching Request</h4>
                </div>
                <div class="card-body">
                    <form asp-action="EditProposal" asp-controller="Matching" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label">Current Supervisor</label>
                            <input type="text" class="form-control" value="@Model.Supervisor?.FullName" disabled />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="supervisorId">Select New Supervisor</label>
                            @Html.DropDownList("supervisorId", (SelectList)ViewBag.Supervisors, "Select a supervisor", new { @class = "form-select", id = "supervisorId" })
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="MyRequests" asp-controller="Matching" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
