@model IEnumerable<Blind_Match_PAS.Models.MatchingRequest>

@{
    ViewData["Title"] = "My Matching Requests";
}

<div class="container mt-5">
    <h1>My Matching Requests</h1>
    <p class="text-muted">Track your supervisor matching requests and confirmations</p>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> You have not sent any matching requests yet.
            <a asp-action="Index" asp-controller="Matching">Browse available supervisors</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Supervisor</th>
                        <th>Contact</th>
                        <th>Status</th>
                        <th>Requested</th>
                        <th class="text-center" style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>
                                @if (request.Status == Blind_Match_PAS.Models.MatchingRequestStatus.Accepted)
                                {
                                    <strong>@request.Supervisor?.FullName</strong>
                                }
                                else
                                {
                                    <em class="text-muted">Anonymous</em>
                                }
                            </td>
                            <td>
                                @if (request.Status == Blind_Match_PAS.Models.MatchingRequestStatus.Accepted)
                                {
                                    <small>@request.Supervisor?.Email</small>
                                }
                                else
                                {
                                    <small class="text-muted">Hidden</small>
                                }
                            </td>
                            <td>
                                <span
                                    class="badge @(request.Status == Blind_Match_PAS.Models.MatchingRequestStatus.Pending ? "bg-warning" : 
                                                                                                                                                                                                                                                                           request.Status == Blind_Match_PAS.Models.MatchingRequestStatus.Accepted ? "bg-success" : "bg-danger")">
                                    @request.Status
                                </span>
                            </td>
                            <td>@request.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-center">
                                @if (request.Status == Blind_Match_PAS.Models.MatchingRequestStatus.Pending)
                                {
                                    <a asp-action="EditProposal" asp-controller="Matching" asp-route-requestId="@request.Id"
                                           class="btn btn-sm btn-warning me-1" title="Edit Request">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form asp-action="WithdrawProposal" asp-controller="Matching" method="post" class="d-inline"
                                          onsubmit="return confirm('Withdraw this request? This action cannot be undone.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="requestId" value="@request.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" title="Withdraw Request">
                                            <i class="bi bi-trash"></i> Withdraw
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">Finalized</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-4">
        <a asp-action="Index" asp-controller="Matching" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Back to Available Supervisors
        </a>
    </div>
</div>
