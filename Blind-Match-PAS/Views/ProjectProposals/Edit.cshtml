@model Blind_Match_PAS.Models.ProjectProposal

@{
    ViewData["Title"] = "Edit Project Proposal";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>
            <hr />

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="Edit" asp-controller="ProjectProposals" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="e.g., AI-Powered Recommendation System" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                    <small class="form-text text-muted">
                        Must start with an uppercase letter and be 5-200 characters long.
                    </small>
                </div>

                <div class="mb-3">
                    <label asp-for="Abstract" class="form-label"></label>
                    <textarea asp-for="Abstract" class="form-control" rows="4"
                              placeholder="Describe your project proposal (20-1000 characters)"></textarea>
                    <span asp-validation-for="Abstract" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TechnicalStack" class="form-label"></label>
                    <input asp-for="TechnicalStack" class="form-control"
                           placeholder="e.g., Python, TensorFlow, React, Node.js" />
                    <span asp-validation-for="TechnicalStack" class="text-danger"></span>
                    <small class="form-text text-muted">
                        List the technologies and frameworks you'll use (5-500 characters).
                    </small>
                </div>

                <div class="mb-3">
                    <label asp-for="ResearchAreaId" class="form-label"></label>
                    <select asp-for="ResearchAreaId" class="form-select" asp-items="ViewBag.ResearchAreas">
                        <option value="">-- Select a Research Area --</option>
                    </select>
                    <span asp-validation-for="ResearchAreaId" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Update Proposal</button>
                    <a href="@Url.Action("Index", "ProjectProposals")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
