@model IEnumerable<Blind_Match_PAS.Models.Project>
@using System.Security.Claims
@{
    ViewData["Title"] = "Available Projects";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Available Projects</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No matching projects are available right now.</div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="card-title mb-0">@item.Title</h5>
                                <small class="muted-small">Project #@item.Id</small>
                            </div>
                            <span class="badge-custom">@item.TechStack?.Split(',').FirstOrDefault()</span>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@item.Abstract</p>
                            <p class="mb-0"><strong>Research Area:</strong> @item.ResearchArea</p>
                        </div>
                        <div class="card-footer d-flex justify-content-between">
                            <div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
