@model Blind_Match_PAS.Models.Project

@{
    ViewData["Title"] = "Delete Project";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h2 class="card-title mb-0">Confirm Delete</h2>
                    <a asp-action="Index" class="btn btn-sm btn-light">Back to List</a>
                </div>
                <div class="card-body">
                    <p>Are you sure you want to delete this project?</p>

                    <dl class="row">
                        <dt class="col-sm-3">Title</dt>
                        <dd class="col-sm-9">@Model.Title</dd>

                        <dt class="col-sm-3">Abstract</dt>
                        <dd class="col-sm-9">@Model.Abstract</dd>

                        <dt class="col-sm-3">Tech Stack</dt>
                        <dd class="col-sm-9">@Model.TechStack</dd>

                        <dt class="col-sm-3">Research Area</dt>
                        <dd class="col-sm-9">@Model.ResearchArea</dd>
                    </dl>

                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-danger">Delete</button>
                        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
