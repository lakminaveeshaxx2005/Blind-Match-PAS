@model Blind_Match_PAS.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h2>Edit Project</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                        <input asp-for="Id" type="hidden" />
                        <input asp-for="StudentId" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Abstract" class="form-label"></label>
                            <textarea asp-for="Abstract" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Abstract" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TechStack" class="form-label"></label>
                            <input asp-for="TechStack" class="form-control" />
                            <span asp-validation-for="TechStack" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ResearchArea" class="form-label"></label>
                            <input asp-for="ResearchArea" class="form-control" />
                            <span asp-validation-for="ResearchArea" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
