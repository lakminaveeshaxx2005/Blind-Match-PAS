@model IEnumerable<Blind_Match_PAS.Models.Project>
@using System.Security.Claims
@{
    ViewData["Title"] = "Projects";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Projects</h1>
        <a asp-action="Create" class="btn btn-primary">Create Project</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No projects are available yet.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Abstract</th>
                    <th>Tech Stack</th>
                    <th>Research Area</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Title)</td>
                        <td>@Html.DisplayFor(modelItem => item.Abstract)</td>
                        <td>@Html.DisplayFor(modelItem => item.TechStack)</td>
                        <td>@Html.DisplayFor(modelItem => item.ResearchArea)</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary me-1">Details</a>
                            @if (item.StudentId == currentUserId)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
