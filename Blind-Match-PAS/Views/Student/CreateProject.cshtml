@model Blind_Match_PAS.Models.Project

@{
    ViewData["Title"] = "Create Project";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>
            <hr />

            <form asp-action="CreateProject" asp-controller="Student" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="Enter the project title" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Abstract" class="form-label"></label>
                    <textarea asp-for="Abstract" class="form-control" rows="5"
                              placeholder="Describe your project"></textarea>
                    <span asp-validation-for="Abstract" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TechStack" class="form-label"></label>
                    <input asp-for="TechStack" class="form-control" placeholder="e.g. ASP.NET Core, EF Core, React" />
                    <span asp-validation-for="TechStack" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ResearchArea" class="form-label"></label>
                    <input asp-for="ResearchArea" class="form-control" placeholder="Enter the research area" />
                    <span asp-validation-for="ResearchArea" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Submit Project</button>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
