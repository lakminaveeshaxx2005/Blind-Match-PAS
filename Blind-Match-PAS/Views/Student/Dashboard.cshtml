@model IEnumerable<Blind_Match_PAS.Models.StudentProjectProposalViewModel>

@{
    ViewData["Title"] = "Student Dashboard";
}

<h1>Student Dashboard</h1>

<p>Welcome to your dashboard. Here you can view your submitted project proposals.</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
else if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Abstract</th>
                <th>Technical Stack</th>
                <th>Research Area</th>
                <th>Status</th>
                <th>Supervisor</th>
                <th>Contact</th>
                <th>Submitted At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var proposal in Model)
            {
                <tr>
                    <td>@proposal.Title</td>
                    <td>@proposal.Abstract</td>
                    <td>@proposal.TechnicalStack</td>
                    <td>@proposal.ResearchAreaName</td>
                    <td>
                        <span class="badge badge-info">@proposal.Status</span>
                    </td>
                    <td>
                        @if (proposal.Status == Blind_Match_PAS.Models.ProjectStatus.Matched && !string.IsNullOrEmpty(proposal.SupervisorName))
                        {
                            @proposal.SupervisorName
                        }
                        else
                        {
                            <em>Hidden until match</em>
                        }
                    </td>
                    <td>
                        @if (proposal.Status == Blind_Match_PAS.Models.ProjectStatus.Matched && !string.IsNullOrEmpty(proposal.SupervisorEmail))
                        {
                            @proposal.SupervisorEmail
                        }
                        else
                        {
                            <em>Hidden until match</em>
                        }
                    </td>
                    <td>@proposal.CreatedAt.ToString("g")</td>
                    <td>
                        <a asp-controller="Student" asp-action="FindMatches" asp-route-proposalId="@proposal.Id"
                               class="btn btn-sm btn-primary">
                            Find Matches
                        </a>
                        @if (proposal.Status == Blind_Match_PAS.Models.ProjectStatus.Pending)
                        {
                            <a asp-controller="Student" asp-action="EditProposal" asp-route-id="@proposal.Id" class="btn btn-sm btn-secondary">
                                Edit
                            </a>
                            <form asp-action="WithdrawProposal" asp-controller="Student" asp-route-id="@proposal.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to withdraw this proposal?');">
                                    Withdraw
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>You have not submitted any project proposals yet.</p>
}

<a asp-action="SubmitProposal" class="btn btn-primary">Submit New Proposal</a>