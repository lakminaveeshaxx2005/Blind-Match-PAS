@model IEnumerable<Blind_Match_PAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Student Dashboard";
}

<h1>Student Dashboard</h1>

<p>Welcome to your dashboard. Here you can view your submitted project proposals.</p>

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Abstract</th>
                <th>Technical Stack</th>
                <th>Research Area</th>
                <th>Status</th>
                <th>Submitted At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var proposal in Model)
            {
                <tr>
                    <td>@proposal.Title</td>
                    <td>@proposal.Abstract</td>
                    <td>@proposal.TechnicalStack</td>
                    <td>@proposal.ResearchArea?.Name</td>
                    <td>
                        <span class="badge badge-info">@proposal.Status</span>
                    </td>
                    <td>@proposal.CreatedAt.ToString("g")</td>
                    <td>
                        <a asp-controller="Student" asp-action="FindMatches" asp-route-proposalId="@proposal.Id"
                               class="btn btn-sm btn-primary">
                            Find Matches
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>You have not submitted any project proposals yet.</p>
}

<a asp-action="SubmitProposal" class="btn btn-primary">Submit New Proposal</a>