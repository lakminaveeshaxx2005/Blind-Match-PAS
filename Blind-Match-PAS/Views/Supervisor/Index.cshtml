@model IEnumerable<Blind_Match_PAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Pending Project Proposals";
}

<div class="container mt-5">
    <h1>@ViewData["Title"]</h1>
    <p class="text-muted">Browse pending project proposals from students. Student identities are kept anonymous.</p>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            No pending project proposals at this time.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var proposal in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@proposal.Title</h5>
                            <p class="card-text text-muted">
                                <strong>Research Area:</strong> @proposal.ResearchArea?.Name
                            </p>

                            <div class="mb-3">
                                <h6 class="card-subtitle mb-2">Abstract</h6>
                                <p class="card-text">
                                    @if (proposal.Abstract.Length > 150)
                                    {
                                        @proposal.Abstract.Substring(0, 150)
                                        <span>...</span>
                                    }
                                    else
                                    {
                                        @proposal.Abstract
                                    }
                                </p>
                            </div>

                            <div class="mb-3">
                                <h6 class="card-subtitle mb-2">Technical Stack</h6>
                                <p class="card-text">
                                    <small class="text-muted">@proposal.TechnicalStack</small>
                                </p>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top">
                            <button type="button" class="btn btn-primary btn-sm w-100" data-bs-toggle="modal"
                                    data-bs-target="#detailsModal@(proposal.Id)">
                                View Details
                            </button>
                            <form asp-action="AcceptProposal" asp-controller="Supervisor" method="post" class="mt-2">
                                <input type="hidden" name="id" value="@proposal.Id" />
                                <button type="submit" class="btn btn-success btn-sm w-100">
                                    Express Interest
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Modal for Full Details -->
                    <div class="modal fade" id="detailsModal@(proposal.Id)" tabindex="-1"
                         aria-labelledby="detailsModalLabel@(proposal.Id)" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="detailsModalLabel@(proposal.Id)">@proposal.Title</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <h6 class="fw-bold">Research Area</h6>
                                        <p>@proposal.ResearchArea?.Name</p>
                                    </div>
                                    <div class="mb-3">
                                        <h6 class="fw-bold">Abstract</h6>
                                        <p>@proposal.Abstract</p>
                                    </div>
                                    <div class="mb-3">
                                        <h6 class="fw-bold">Technical Stack</h6>
                                        <p>@proposal.TechnicalStack</p>
                                    </div>
                                    <div class="alert alert-info" role="alert">
                                        <strong>Note:</strong> Student identity is kept anonymous to ensure unbiased evaluation.
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <form asp-action="AcceptProposal" asp-controller="Supervisor" method="post"
                                          class="d-inline">
                                        <input type="hidden" name="id" value="@proposal.Id" />
                                        <button type="submit" class="btn btn-success">Express Interest</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
}
